# ─────────────────────────────────────────────────────────────────────────
# ALERT environment configuration
# Copy this file to `.env` and fill in your keys:   cp .env.example .env
# `.env` is gitignored and must never be committed.
# ─────────────────────────────────────────────────────────────────────────

# REQUIRED — used for Whisper transcription and the GPT chat orchestrator.
OPENAI_API_KEY=

# OPTIONAL — enables Gemini multimodal video analysis + agentic visual QA.
# Leave ENABLE_GEMINI_ANALYSIS=false to run transcription/audio analysis only.
GEMINI_API_KEY=
ENABLE_GEMINI_ANALYSIS=false
GEMINI_MODEL=gemini-2.5-flash

# Duration (seconds) of each video chunk sent to Gemini for analysis.
VIDEO_CHUNK_SECONDS=300

# OPTIONAL — override the chat model (default: gpt-4o-mini).
# OPENAI_CHAT_MODEL=gpt-4o-mini

# ─── Infrastructure (defaults match docker-compose) ──────────────────────
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/multimedia_events
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── Upload limits & CORS (optional) ─────────────────────────────────────
# Maximum upload size in megabytes (default: 2048).
# MAX_UPLOAD_MB=2048
# Comma-separated list of allowed browser origins for CORS.
# CORS_ALLOW_ORIGINS=http://localhost:5001,http://localhost:5173

# ─── Frontend ────────────────────────────────────────────────────────────
# VITE_API_BASE_URL=/api
